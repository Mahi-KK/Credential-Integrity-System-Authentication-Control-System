# Local Django settings
DJANGO_SECRET_KEY=replace-this-with-a-long-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,testserver

# Use sqlite automatically when DB_ENGINE is not mysql.
# Set DB_ENGINE=mysql to use the MySQL settings below.
DB_ENGINE=mysql
MYSQL_DATABASE=password_reuse_db
MYSQL_USER=password_reuse_user
MYSQL_PASSWORD=password_reuse_pass
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
